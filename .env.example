# Optional: override inbox (default cafe.lovepier@gmail.com)
MAIL_TO=cafe.lovepier@gmail.com

# Without SMTP, forms send via FormSubmit from the visitor's browser.
# The first submission triggers an activation email to MAIL_TO — click the link once.

# Optional: send via your own Gmail SMTP instead of FormSubmit
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=cafe.lovepier@gmail.com
# SMTP_PASS=your_gmail_app_password
# MAIL_FROM=cafe.lovepier@gmail.com
